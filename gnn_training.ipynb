import torch
import torch.nn.functional as F
import numpy as np
from torch_geometric.datasets import Planetoid
from torch_geometric.nn import GCNConv, GATConv
from sklearn.svm import SVC
from sklearn.metrics import accuracy_score

# =========================
# LOAD DATASET
# =========================
dataset = Planetoid(root='./data', name='CiteSeer')
data = dataset[0]

class_names = {
    0: "Agents",
    1: "AI",
    2: "DB",
    3: "IR",
    4: "ML",
    5: "HCI"
}

print("Dataset:", dataset)
print("Nodes:", data.num_nodes)
print("Edges:", data.num_edges)
print("Features:", dataset.num_features)
print("Classes:", dataset.num_classes)

print("\nClass Details")
print("--------------------------")
for class_id, class_name in class_names.items():
    count = (data.y == class_id).sum().item()
    print(f"Class {class_id}: {class_name} ({count} nodes)")

# =========================
# GCN MODEL
# =========================
class GCN(torch.nn.Module):
    def __init__(self):
        super().__init__()
        self.conv1 = GCNConv(dataset.num_features, 16)
        self.conv2 = GCNConv(16, dataset.num_classes)

    def forward(self, data):
        x, edge_index = data.x, data.edge_index
        x = self.conv1(x, edge_index)
        x = F.relu(x)
        x = self.conv2(x, edge_index)
        return F.log_softmax(x, dim=1)

# =========================
# GAT MODEL
# =========================
class GAT(torch.nn.Module):
    def __init__(self):
        super().__init__()
        self.gat1 = GATConv(dataset.num_features, 8, heads=8, dropout=0.6)
        self.gat2 = GATConv(8 * 8, dataset.num_classes, heads=1, concat=False, dropout=0.6)

    def forward(self, data):
        x, edge_index = data.x, data.edge_index
        x = F.dropout(x, p=0.6, training=self.training)
        x = self.gat1(x, edge_index)
        x = F.elu(x)
        x = F.dropout(x, p=0.6, training=self.training)
        x = self.gat2(x, edge_index)
        return F.log_softmax(x, dim=1)

def train_model(model, epochs=50):
    optimizer = torch.optim.Adam(model.parameters(), lr=0.01, weight_decay=5e-4)
    model.train()
    for epoch in range(epochs):
        optimizer.zero_grad()
        out = model(data)
        loss = F.nll_loss(out[data.train_mask], data.y[data.train_mask])
        loss.backward()
        optimizer.step()
    return model

def test_model(model, name):
    model.eval()
    pred = model(data).argmax(dim=1)
    acc = accuracy_score(data.y[data.test_mask].cpu(), pred[data.test_mask].cpu())
    print(f"{name} Accuracy: {acc:.4f}")
    return pred, acc

# Train GCN
gcn = GCN()
gcn = train_model(gcn)
gcn_pred, gcn_acc = test_model(gcn, "GCN")

# Train GAT
gat = GAT()
gat = train_model(gat)
gat_pred, gat_acc = test_model(gat, "GAT")

# SVM
X = data.x.cpu().numpy()
y = data.y.cpu().numpy()

svm = SVC()
svm.fit(X[data.train_mask], y[data.train_mask])
svm_pred = svm.predict(X[data.test_mask])
svm_acc = accuracy_score(y[data.test_mask], svm_pred)

print(f"SVM Accuracy: {svm_acc:.4f}")

print("\nModel Comparison")
print("--------------------------")
print(f"GCN Accuracy : {gcn_acc:.4f}")
print(f"GAT Accuracy : {gat_acc:.4f}")
print(f"SVM Accuracy : {svm_acc:.4f}")

node_id = 25
predicted_class = gcn_pred[node_id].item()
actual_class = data.y[node_id].item()

print("\nNode Analysis")
print("--------------------------")
print("Node ID:", node_id)
print("Predicted Class:", class_names[predicted_class])
print("Actual Class:", class_names[actual_class])

neighbors = data.edge_index[1][data.edge_index[0] == node_id].tolist()

print("\nConnected Neighbor Nodes:")
for n in neighbors[:5]:
    print(f"Node {n} -> {class_names[data.y[n].item()]}")
